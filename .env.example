# ── Ragdoll Configuration ───────────────────────────────────────────────
#
# Copy this file to .env and edit with your values.
# Alternatively, use ~/.ragdoll/config.toml for persistent user settings.
#
# All variables are prefixed with RAGDOLL_ and map to Settings fields.
# See docs/configuration.md for the full 4-layer precedence explanation.

# ── JIRA ────────────────────────────────────────────────────────────────
RAGDOLL_JIRA_URL=https://jira.example.com
RAGDOLL_JIRA_USER=your.username
RAGDOLL_JIRA_TOKEN=your_api_token_or_pat
RAGDOLL_JIRA_AUTH_METHOD=pat          # "pat" for Data Center, "basic" for Cloud
RAGDOLL_JIRA_BATCH_SIZE=50            # issues per API request

# ── Ollama / LLM ───────────────────────────────────────────────────────
RAGDOLL_OLLAMA_HOST=http://localhost:11434
RAGDOLL_EMBED_MODEL=nomic-embed-text
RAGDOLL_CHAT_MODEL=gpt-oss:20b
RAGDOLL_TEMPERATURE=0.3

# ── Storage ─────────────────────────────────────────────────────────────
RAGDOLL_DATA_DIR=~/.ragdoll/data
RAGDOLL_COLLECTION_NAME=ragdoll

# ── Chunking & Retrieval ───────────────────────────────────────────────
RAGDOLL_CHUNK_SIZE=1000               # characters per chunk
RAGDOLL_CHUNK_OVERLAP=200             # overlap between consecutive chunks
RAGDOLL_TOP_K=20                      # default number of chunks to retrieve
